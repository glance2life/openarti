# API server (server-side) — used by Next.js server components to call the API
OPENARTI_API_URL=http://localhost:3001

# API server (browser-side) — used by client components
NEXT_PUBLIC_API_URL=http://localhost:3001

# Realtime driver: "polling" (default, zero-dep) or "supabase" (Broadcast)
NEXT_PUBLIC_REALTIME_DRIVER=polling

# Polling interval in ms (polling driver only)
NEXT_PUBLIC_REALTIME_POLL_INTERVAL_MS=5000

# Supabase Broadcast (supabase driver only — safe to expose, public anon key)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
