DATABASE_URL=postgresql://openarti:openarti@localhost:5432/openarti
STORAGE_DIR=~/.openarti/storage

# Auth (required)
BETTER_AUTH_SECRET=change-me-to-a-random-string
BETTER_AUTH_URL=http://localhost:3001

# Admin
# ADMIN_EMAIL: if set, the user registering with this email is auto-promoted to admin
#              on signup. Also used by the db:seed script as the initial admin email.
# ADMIN_PASSWORD: only used by db:seed (random if blank). Not used at runtime.
ADMIN_EMAIL=admin@openarti.dev
ADMIN_PASSWORD=

# Registration (default: invite-only)
ALLOW_REGISTRATION=false

# Google OAuth (optional — leave blank to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Web origin for CORS
WEB_ORIGIN=http://localhost:3000

# Cross-subdomain session cookie (optional).
# Set to the shared parent domain (e.g. .example.com) when the web app and
# API live on different subdomains (www.example.com + api.example.com).
# Leave blank for single-origin or localhost deployments.
COOKIE_DOMAIN=

# Realtime Broadcast (optional — leave blank to disable server-side publish;
# browsers fall back to polling /head automatically)
# Use a Supabase secret key (sb_secret_...) here so private channels also work.
# Legacy SUPABASE_ANON_KEY / SUPABASE_PUBLISHABLE_KEY are still accepted as fallback.
SUPABASE_URL=
SUPABASE_SECRET_KEY=
