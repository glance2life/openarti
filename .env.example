DATABASE_URL=postgresql://openarti:openarti@localhost:5432/openarti
GIT_DATA_DIR=./data/repos

# Auth (required)
BETTER_AUTH_SECRET=change-me-to-a-random-string
BETTER_AUTH_URL=http://localhost:3001

# Admin seed credentials (optional — generated if not set)
ADMIN_EMAIL=admin@openarti.dev
ADMIN_PASSWORD=

# Registration (default: invite-only)
ALLOW_REGISTRATION=false

# Google OAuth (optional — leave blank to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Web origin for CORS
WEB_ORIGIN=http://localhost:3000
